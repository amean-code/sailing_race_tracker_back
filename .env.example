# PostgreSQL (local install)
DATABASE_URL=postgresql://postgres:password@localhost:5432/sailing_race_tracker

# Docker alternative (docker compose up -d)
# DATABASE_URL=postgresql://bayk:bayk_secret@localhost:5433/bayk_tracker

# JWT secret — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Ana frontend origin (CORS)
FRONTEND_URL=http://localhost:5173

# Ek izinli origin'ler — virgülle ayrılmış (FRONTEND_URL'e eklenir)
# Mobil/LAN testi: http://192.168.x.x:5173  |  prod: https://app.example.com
CORS_ORIGINS=
# CORS_ORIGINS=http://192.168.1.10:5173,https://app.example.com

# Server port
PORT=5174

APP_NAME=BAYK Tracker API

# --- Optional: default SMTP (admin panel can override) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# --- Optional: Evolution WhatsApp API (admin panel can override) ---
# EVOLUTION_API_URL=https://evolution.example.com
# EVOLUTION_API_KEY=
# EVOLUTION_INSTANCE=bayk
